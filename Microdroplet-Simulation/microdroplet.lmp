#Water + NaCl (Microdroplet)

#Initialization
units real 
dimension 3 # 3D
atom_style full 
boundary p p p

#System definition
read_data microdroplet.data

#Settings
pair_style lj/cut/coul/long 2.5 #LJ + long-range Coulomb for 2.5 angstroms
kspace_style pppm 1.0e-4 #coulomb interactions beyond the cutoff

set type 1 charge -1.0000 # Set charge (for Cl)
set type 2 charge 0.4238 # Set charge (for H)
set type 3 charge 1.0000 # Set charge (for Na)
set type 4 charge -0.8476 # Set charge (for O)
pair_coeff 1 1 0.0719 4.4200 # Sets LJ values epsilon, sigma (for Cl)
pair_coeff 2 2 0.0000 0.0000 # Sets LJ values epsilon, sigma (for H)
pair_coeff 3 3 0.0313 2.6000 # Sets LJ values epsilon, sigma (for Na)
pair_coeff 4 4 0.1553 3.1660 # Sets LJ values epsilon, sigma (for O)

bond_style harmonic 
bond_coeff 1 450 0.9572    
angle_style harmonic
angle_coeff * 55.0 109.47 

#Monitoring
minimize 1.0e-4 1.0e-6 100 1000


group water type 2 4
fix 1 water shake 0.0001 10 1000 b 1 a 1 # (b 1 - bond type 1) (a 1 - angle type 1)
fix 2 all nvt temp 300 300 100 #needs to be nvt (npt for bulk liquids)

thermo_style custom step temp etotal
thermo 200

velocity all create 250.0 12345 mom yes rot yes #(mom yes - removes net linear momentum) (rot yes - removes net rotation) 

reset_timestep 0
dump traj all atom 100 dump_microdroplet.lammpstrj

#Run
timestep 1.0
run 50000

write_data microdroplet_full_test.data nocoeff